# ── SAVLUNE × MITSUBISHI — Environment Variables ──
# Copy this file to .env.local and fill in real values.
# The app runs fully without Supabase: leads fall back to local JSON storage
# at data/leads.local.json (dev only — not persisted on serverless hosts).

# Supabase (optional — enables persistent lead storage + admin CSV import)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp sales number, digits only, country code first (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=6282156067048

# Admin dashboard credentials (simple gate — replace with real auth before
# handling real customer data at scale)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Site URL used for canonical links / OG tags
NEXT_PUBLIC_SITE_URL=https://savlune-mitsubishi-samarinda.example.com
